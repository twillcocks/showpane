#!/usr/bin/env bash
set -euo pipefail

# Showpane setup script
# Installs skills into ~/.claude/skills/showpane and configures the portal app

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHOWPANE_DIR="${HOME}/.showpane"
CURRENT_TOOLCHAIN_LINK="${SHOWPANE_DIR}/current"

# ─── Argument parsing ────────────────────────────────────────
CLOUD_MODE=false
SKILL_PREFIX=0  # Default: flat names (/portal-create, /portal-deploy)

for arg in "$@"; do
  case "$arg" in
    --cloud)     CLOUD_MODE=true ;;
    --prefix)    SKILL_PREFIX=1 ;;
    --no-prefix) SKILL_PREFIX=0 ;;
    --help|-h)
      echo "Usage: ./setup [OPTIONS]"
      echo ""
      echo "Options:"
      echo "  --cloud      Set up Showpane Cloud (hosted service)"
      echo "  --prefix     Install skills as /showpane-portal-create, /showpane-portal-deploy, ..."
      echo "  --no-prefix  Install skills as /portal-create, /portal-deploy, ... (default)"
      echo "  --help, -h   Show this help message"
      exit 0
      ;;
  esac
done

# ─── Skill installation functions ────────────────────────────
install_skills() {
  local source_dir="$1"
  local skills_dir="${HOME}/.claude/skills"
  mkdir -p "$skills_dir"
  mkdir -p "$SHOWPANE_DIR"

  # Clean up old-style single symlink
  rm -f "$skills_dir/showpane" 2>/dev/null
  rm -rf "$skills_dir/showpane-shared" 2>/dev/null
  ln -snf "$source_dir/skills/shared" "$skills_dir/showpane-shared"
  ln -snf "$source_dir" "$CURRENT_TOOLCHAIN_LINK"

  mkdir -p "$SHOWPANE_DIR/bin"
  ln -snf "$source_dir/bin/showpane-config" "$SHOWPANE_DIR/bin/showpane-config"

  local count=0
  local installed=()
  for skill_dir in "$source_dir"/skills/portal-*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    local dir_name
    dir_name=$(basename "$skill_dir")

    # Read name from SKILL.md frontmatter
    local skill_name
    skill_name=$(grep -m1 '^name:' "$skill_dir/SKILL.md" 2>/dev/null | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]')
    [ -z "$skill_name" ] && skill_name="$dir_name"

    # Apply prefix if requested
    local link_name
    if [ "$SKILL_PREFIX" -eq 1 ]; then
      case "$skill_name" in
        showpane-*) link_name="$skill_name" ;;
        *)          link_name="showpane-$skill_name" ;;
      esac
    else
      link_name="$skill_name"
    fi

    local target="$skills_dir/$link_name"

    # Upgrade old symlinks to real directories
    [ -L "$target" ] && rm -f "$target"

    mkdir -p "$target"
    [ -L "$target/SKILL.md" ] && rm "$target/SKILL.md"
    ln -snf "$skill_dir/SKILL.md" "$target/SKILL.md"

    installed+=("$link_name")
    count=$((count + 1))
  done

  # Clean up stale entries from opposite prefix mode
  if [ "$SKILL_PREFIX" -eq 1 ]; then
    cleanup_unprefixed_skills "$source_dir" "$skills_dir"
  else
    cleanup_prefixed_skills "$source_dir" "$skills_dir"
  fi

  echo "  $count skills installed: ${installed[*]}"
}

cleanup_unprefixed_skills() {
  local source_dir="$1"
  local skills_dir="$2"
  for skill_dir in "$source_dir"/skills/portal-*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    local name
    name=$(basename "$skill_dir")
    local target="$skills_dir/$name"
    if [ -d "$target" ] && [ -L "$target/SKILL.md" ]; then
      local link_dest
      link_dest=$(readlink "$target/SKILL.md" 2>/dev/null || true)
      case "$link_dest" in
        *showpane*|*portal*)
          rm -rf "$target"
          ;;
      esac
    fi
  done
}

cleanup_prefixed_skills() {
  local source_dir="$1"
  local skills_dir="$2"
  for skill_dir in "$source_dir"/skills/portal-*/; do
    [ -f "$skill_dir/SKILL.md" ] || continue
    local name
    name=$(basename "$skill_dir")
    local prefixed="$skills_dir/showpane-$name"
    if [ -d "$prefixed" ] && [ -L "$prefixed/SKILL.md" ]; then
      local link_dest
      link_dest=$(readlink "$prefixed/SKILL.md" 2>/dev/null || true)
      case "$link_dest" in
        *showpane*|*portal*)
          rm -rf "$prefixed"
          ;;
      esac
    fi
  done
}

# ─── Cloud setup flow ────────────────────────────────────────
if [ "$CLOUD_MODE" = true ]; then
  echo "=== Setting up Showpane Cloud... ==="
  echo ""

  install_skills "$SCRIPT_DIR"

  # Ensure config directory exists
  if [ ! -d "$SHOWPANE_DIR" ]; then
    echo ""
    echo "Creating ${SHOWPANE_DIR}..."
    mkdir -p "$SHOWPANE_DIR"
    chmod 700 "$SHOWPANE_DIR"
  fi

  # Run the CLI login flow
  echo ""
  if command -v showpane &>/dev/null; then
    showpane login
  elif [ -f "$SCRIPT_DIR/packages/cli/src/index.ts" ]; then
    npx --yes tsx "$SCRIPT_DIR/packages/cli/src/index.ts" login
  else
    npx --yes showpane login
  fi

  # After login, set deploy_mode to "cloud" in the config
  if [ -f "$SHOWPANE_DIR/config.json" ]; then
    # Use node to merge deploy_mode into existing config (preserves other keys)
    node -e "
      const fs = require('fs');
      const p = '$SHOWPANE_DIR/config.json';
      const cfg = JSON.parse(fs.readFileSync(p, 'utf-8'));
      cfg.deploy_mode = 'cloud';
      fs.writeFileSync(p, JSON.stringify(cfg, null, 2) + '\n');
    "
  else
    # Login didn't create a config (shouldn't happen), write a minimal one
    cat > "$SHOWPANE_DIR/config.json" << EOF
{
  "deploy_mode": "cloud"
}
EOF
    chmod 600 "$SHOWPANE_DIR/config.json"
  fi

  echo ""
  echo "=== Cloud setup complete! ==="
  echo ""
  echo "You're connected to Showpane Cloud!"
  echo "Create portals with Claude Code, then deploy with /portal deploy."
  echo ""
  exit 0
fi

# ─── Self-hosted setup flow (default) ────────────────────────

echo "=== Showpane Setup ==="
echo ""

# ─── Install skills ───────────────────────────────────────────
install_skills "$SCRIPT_DIR"

# Make bin scripts executable
chmod +x "$SCRIPT_DIR/bin/showpane-config" 2>/dev/null || true

# ─── Create config directory ──────────────────────────────────
if [ ! -d "$SHOWPANE_DIR" ]; then
  echo ""
  echo "Creating ${SHOWPANE_DIR}..."
  mkdir -p "$SHOWPANE_DIR"
  chmod 700 "$SHOWPANE_DIR"
fi

# ─── Install app dependencies ────────────────────────────────
if [ ! -f "$SCRIPT_DIR/app/package.json" ]; then
  echo "Error: app/package.json not found. Are you in the showpane repo root?"
  exit 1
fi

echo ""
echo "Installing app dependencies..."
cd "$SCRIPT_DIR/app"
npm install --silent 2>/dev/null || npm install

# ─── Generate Prisma client ──────────────────────────────────
echo ""
echo "Generating Prisma client..."
cd "$SCRIPT_DIR/app"
npx prisma generate

# ─── Write initial config if none exists ──────────────────────
if [ ! -f "$SHOWPANE_DIR/config.json" ]; then
  echo ""
  echo "Writing initial config..."
  cat > "$SHOWPANE_DIR/config.json" << EOF
{
  "app_path": "$SCRIPT_DIR/app",
  "deploy_mode": "local",
  "orgSlug": "",
  "telemetry": "off"
}
EOF
  chmod 600 "$SHOWPANE_DIR/config.json"
  echo "  Config: ${SHOWPANE_DIR}/config.json (chmod 600)"
fi

echo ""
echo "=== Setup complete! ==="
echo ""
echo "Skills installed:   ${HOME}/.claude/skills/"
echo "Config:             ${SHOWPANE_DIR}/config.json"
echo "App:                ${SCRIPT_DIR}/app"
echo ""
echo "Next steps:"
echo "  1. Configure your portal:  /portal setup"
echo "  2. Or start fresh:         /portal onboard"
echo ""
echo "Quick start (if you have a database ready):"
echo "  1. Copy app/.env.example to app/.env and set DATABASE_URL + AUTH_SECRET"
echo "  2. Run: cd app && npx prisma migrate dev"
echo "  3. Run: cd app && npx prisma db seed"
echo "  4. Run: cd app && npm run dev"
echo "  5. Visit: http://localhost:3000/client"
