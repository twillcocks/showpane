#!/usr/bin/env bash
set -euo pipefail

# Showpane setup script
# Installs skills into ~/.claude/skills/showpane and configures the portal app

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS_DIR="${HOME}/.claude/skills/showpane"
SHOWPANE_DIR="${HOME}/.showpane"

# ─── Argument parsing ────────────────────────────────────────
CLOUD_MODE=false
for arg in "$@"; do
  case "$arg" in
    --cloud) CLOUD_MODE=true ;;
  esac
done

# ─── Cloud setup flow ────────────────────────────────────────
if [ "$CLOUD_MODE" = true ]; then
  echo "=== Setting up Showpane Cloud... ==="
  echo ""

  # Install skills (needed for both modes)
  echo "Installing skills to ${SKILLS_DIR}..."
  mkdir -p "$(dirname "$SKILLS_DIR")"
  ln -sfn "$SCRIPT_DIR/skills" "$SKILLS_DIR"
  echo "  14 skills installed."

  # Ensure config directory exists
  if [ ! -d "$SHOWPANE_DIR" ]; then
    echo ""
    echo "Creating ${SHOWPANE_DIR}..."
    mkdir -p "$SHOWPANE_DIR"
    chmod 700 "$SHOWPANE_DIR"
  fi

  # Run the CLI login flow
  echo ""
  if command -v showpane &>/dev/null; then
    showpane login
  elif [ -f "$SCRIPT_DIR/packages/cli/src/index.ts" ]; then
    npx --yes tsx "$SCRIPT_DIR/packages/cli/src/index.ts" login
  else
    npx --yes showpane login
  fi

  # After login, set deploy_mode to "cloud" in the config
  if [ -f "$SHOWPANE_DIR/config.json" ]; then
    # Use node to merge deploy_mode into existing config (preserves other keys)
    node -e "
      const fs = require('fs');
      const p = '$SHOWPANE_DIR/config.json';
      const cfg = JSON.parse(fs.readFileSync(p, 'utf-8'));
      cfg.deploy_mode = 'cloud';
      fs.writeFileSync(p, JSON.stringify(cfg, null, 2) + '\n');
    "
  else
    # Login didn't create a config (shouldn't happen), write a minimal one
    cat > "$SHOWPANE_DIR/config.json" << EOF
{
  "deploy_mode": "cloud"
}
EOF
    chmod 600 "$SHOWPANE_DIR/config.json"
  fi

  echo ""
  echo "=== Cloud setup complete! ==="
  echo ""
  echo "You're connected to Showpane Cloud!"
  echo "Create portals with Claude Code, then deploy with /portal deploy."
  echo ""
  exit 0
fi

# ─── Self-hosted setup flow (default) ────────────────────────

echo "=== Showpane Setup ==="
echo ""

# ─── Install skills ───────────────────────────────────────────
echo "Installing skills to ${SKILLS_DIR}..."
mkdir -p "$(dirname "$SKILLS_DIR")"
ln -sfn "$SCRIPT_DIR/skills" "$SKILLS_DIR"
echo "  14 skills installed."

# Make bin scripts executable
chmod +x "$SCRIPT_DIR/bin/showpane-config" 2>/dev/null || true

# ─── Create config directory ──────────────────────────────────
if [ ! -d "$SHOWPANE_DIR" ]; then
  echo ""
  echo "Creating ${SHOWPANE_DIR}..."
  mkdir -p "$SHOWPANE_DIR"
  chmod 700 "$SHOWPANE_DIR"
fi

# ─── Install app dependencies ────────────────────────────────
if [ ! -f "$SCRIPT_DIR/app/package.json" ]; then
  echo "Error: app/package.json not found. Are you in the showpane repo root?"
  exit 1
fi

echo ""
echo "Installing app dependencies..."
cd "$SCRIPT_DIR/app"
npm install --silent 2>/dev/null || npm install

# ─── Generate Prisma client ──────────────────────────────────
echo ""
echo "Generating Prisma client..."
npx prisma generate --schema="$SCRIPT_DIR/app/prisma/schema.prisma"

# ─── Write initial config if none exists ──────────────────────
if [ ! -f "$SHOWPANE_DIR/config.json" ]; then
  echo ""
  echo "Writing initial config..."
  cat > "$SHOWPANE_DIR/config.json" << EOF
{
  "app_path": "$SCRIPT_DIR/app",
  "deploy_mode": "docker",
  "orgSlug": "",
  "telemetry": "off"
}
EOF
  chmod 600 "$SHOWPANE_DIR/config.json"
  echo "  Config: ${SHOWPANE_DIR}/config.json (chmod 600)"
fi

echo ""
echo "=== Setup complete! ==="
echo ""
echo "Skills installed:   ${SKILLS_DIR}"
echo "Config:             ${SHOWPANE_DIR}/config.json"
echo "App:                ${SCRIPT_DIR}/app"
echo ""
echo "Next steps:"
echo "  1. Configure your portal:  /portal setup"
echo "  2. Or start fresh:         /portal onboard"
echo ""
echo "Quick start (if you have a database ready):"
echo "  1. Copy app/.env.example to app/.env and set DATABASE_URL + AUTH_SECRET"
echo "  2. Run: cd app && npx prisma migrate dev"
echo "  3. Run: cd app && npx prisma db seed"
echo "  4. Run: cd app && npm run dev"
echo "  5. Visit: http://localhost:3000/client"
